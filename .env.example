# chain-api engine — example configuration
# Copy to .env and fill in the values.
# Leave API_KEY and ADMIN_KEY empty on first run — seed generates and prints them once.

PORT=3000
SQLITE_DB_PATH=./data/chain-api.db

# Bitcoin Core — for local regtest (btc-test-ui/start.sh) use port 18443 and password=bitcoin
# For mainnet/testnet change to the appropriate port (8332/18332) and credentials.
BITCOIN_RPC_URL=http://127.0.0.1:18443
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=bitcoin
BITCOIN_NETWORK=regtest
# Note: wallet names are managed per-tenant (btc_{tenantId}) — no global wallet needed

API_KEY=                  # Auto-generated if empty (starts with cak_)
ADMIN_KEY=                # Auto-generated if empty (starts with aak_)
TENANT_NAME=Default Tenant

BTC_DEFAULT_CONFIRMATIONS=1
BTC_FINALITY_CONFIRMATIONS=6

WORKERS_ENABLED=true
DEPOSIT_MONITOR_INTERVAL_MS=30000
WEBHOOK_DELIVERY_INTERVAL_MS=10000
TX_STATUS_INTERVAL_MS=60000

RATE_LIMIT_PER_MIN=100
LOG_LEVEL=info

# Customer session tokens — used for /v1/me/* endpoints (B2B2C customer auth)
# CUSTOMER_SESSION_SECRET must be at least 32 characters. Generate with: openssl rand -hex 32
CUSTOMER_SESSION_SECRET=change-me-before-production-use-openssl-rand-hex-32
CUSTOMER_SESSION_TTL_SECONDS=3600

# BTC dev xpub — auto-generated by seed on first run for tenant_default.
# Used for customer deposit address derivation (BIP32 m/44'/{coin}'/0' → m/0/{index}).
# Saved here by start.sh for reference only — the engine reads xpub from the DB, not this file.
BTC_DEV_XPUB=
