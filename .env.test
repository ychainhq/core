# chain-api engine — manual test / smoke-test environment
# NOT used by Jest (Jest uses setup-env.ts with :memory: DB).
# Use this when you want to run the engine against a real SQLite file for manual testing.

PORT=3099
SQLITE_DB_PATH=./data/chain-api-test.db

BITCOIN_RPC_URL=http://127.0.0.1:8332
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASSWORD=changeme
BITCOIN_RPC_TIMEOUT_MS=100
BITCOIN_RPC_MAX_ATTEMPTS=1
BITCOIN_RPC_RETRY_DELAY_MS=0
BITCOIN_CORE_PROVISIONING_ENABLED=false
BITCOIN_NETWORK=mainnet

# Fill in after first run of: npx ts-node src/db/seed.ts
API_KEY=
ADMIN_KEY=
TENANT_NAME=Default Tenant

BTC_DEFAULT_CONFIRMATIONS=1
BTC_FINALITY_CONFIRMATIONS=6

WORKERS_ENABLED=false
LOG_LEVEL=info
RATE_LIMIT_PER_MIN=10000
