{
  "name": "chain-api",
  "version": "1.0.1",
  "description": "Crypto REST API for Bitcoin payment processing and custody",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && cp -r src/db/migrations dist/db/migrations",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:seed": "ts-node src/db/seed.ts",
    "test": "jest --runInBand --forceExit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^9.4.3",
    "bip32": "^5.0.1",
    "bitcoinjs-lib": "^6.1.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "tiny-secp256k1": "^2.2.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.30",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.+)\\.js$": "$1"
    },
    "setupFiles": [
      "./tests/integration/setup-env.ts"
    ],
    "testTimeout": 15000,
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  }
}
